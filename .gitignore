.DS_Store
__pycache__/
*.py[cod]

# Large local inputs and generated image outputs
data/video/*
data/raw_frames/*
data/detected_frames/*
data/rectified_frames/*
data/rectified_detected_frames/*
data/equirectangular_frames/*
data/equirectangular_local_test/*
data/equirectangular_rotation_test/*
data/omni_perspective_frames/*

# Keep directory placeholders
!data/video/.gitkeep
!data/raw_frames/.gitkeep
!data/detected_frames/.gitkeep
!data/rectified_frames/.gitkeep
!data/rectified_detected_frames/.gitkeep
!data/equirectangular_frames/.gitkeep
!data/equirectangular_local_test/.gitkeep
!data/equirectangular_rotation_test/.gitkeep
!data/omni_perspective_frames/.gitkeep

# Scratch outputs
src/frame_*.jpg
src/output_perspective.jpg
results/equirectangular_5frame_debug/*
!results/equirectangular_5frame_debug/.gitkeep

# Large generated experiment outputs
results/perspective_detection_experiment/raw_detection/*
results/perspective_detection_experiment/perspective_best/*
results/perspective_detection_experiment/perspective_best_detection/*
results/hybrid_detection_selection/selected_raw/*
results/hybrid_detection_selection/selected_detection/*
results/hybrid_detection_selection/selected_perspective/*
results/hybrid_omnidir_calibration/debug_mapped_points/*
results/hybrid_threshold_calibration/debug_mapped_points/*
results/hybrid_threshold_calibration/threshold_*/*

!results/perspective_detection_experiment/raw_detection/.gitkeep
!results/perspective_detection_experiment/perspective_best/.gitkeep
!results/perspective_detection_experiment/perspective_best_detection/.gitkeep
!results/hybrid_detection_selection/selected_raw/.gitkeep
!results/hybrid_detection_selection/selected_detection/.gitkeep
!results/hybrid_detection_selection/selected_perspective/.gitkeep
!results/hybrid_omnidir_calibration/debug_mapped_points/.gitkeep
!results/hybrid_threshold_calibration/debug_mapped_points/.gitkeep

# Local backups
*_backup.py
